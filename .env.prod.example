# Production .env — placed at root of the deploy folder on the VPS.
# Most values come from GitHub Secrets via the deploy workflow.

# Image versioning (set automatically by CI)
IMAGE_TAG=prod-v1.0.0
DOCKERHUB_NAMESPACE=zstin4

# Domains
API_DOMAIN=api.kevinefray.dev
ADMIN_DOMAIN=admin.kevinefray.dev
PORTFOLIO_DOMAIN=kevinefray.dev

# Traefik
CERT_RESOLVER=letsencrypt

# Backend secrets
JWT_SECRET=replace_with_openssl_rand_hex_64
ADMIN_BOOTSTRAP_EMAIL=admin@kevinefray.dev
ADMIN_BOOTSTRAP_PASSWORD=replace_me_with_strong_password
