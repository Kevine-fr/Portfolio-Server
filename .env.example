# ─── Stack-wide secrets / config ────────────────────────────────────────────
# Generate a strong JWT secret in production with:
#   openssl rand -hex 64
JWT_SECRET=dev_secret_change_me_in_production

# Bootstrap admin user created on first DB run (only if users collection is empty)
ADMIN_BOOTSTRAP_EMAIL=admin@kevinefray.dev
ADMIN_BOOTSTRAP_PASSWORD=ChangeMe!2026

# Public API URL baked into admin's Next.js build (must be browser-reachable)
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
